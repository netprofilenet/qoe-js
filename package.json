{
  "name": "@netprofile/qoe-js",
  "version": "1.0.0",
  "description": "QOE network quality testing library - measure bandwidth, latency, and packet loss",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core.mjs",
      "require": "./dist/core.js",
      "types": "./dist/core.d.ts"
    },
    "./ui": {
      "import": "./dist/ui.mjs",
      "require": "./dist/ui.js",
      "types": "./dist/ui.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "tsconfig.json",
    "vite.config.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "vite build && tsc --emitDeclarationOnly",
    "dev": "vite build --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext ts",
    "format": "prettier --write src"
  },
  "peerDependencies": {
    "chart.js": "^4.4.0"
  },
  "peerDependenciesMeta": {
    "chart.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "terser": "^5.46.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "network",
    "speed-test",
    "latency",
    "bandwidth",
    "webrtc",
    "qoe",
    "quality-of-experience",
    "packet-loss",
    "jitter",
    "performance-monitoring"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/netprofile/qoe-js.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "The Netprofile Authors",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
